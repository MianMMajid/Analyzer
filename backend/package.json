{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run build -w @repo/impact-contract",
    "dev": "tsx watch src/server.ts",
    "pretypecheck": "npm run build -w @repo/impact-contract",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prebuild": "npm run build -w @repo/impact-contract",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "postbuild": "mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "migrate": "tsx src/db/migrate.ts",
    "refresh": "tsx src/jobs/refreshImpactData.ts",
    "export:posthog-90d": "tsx src/jobs/exportPosthogBranchesAndCommits.ts",
    "pretest": "npm run build -w @repo/impact-contract",
    "test": "vitest run",
    "precoverage": "npm run build -w @repo/impact-contract",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@repo/impact-contract": "0.0.0",
    "fastify": "^5.6.2",
    "pg": "^8.22.0",
    "pg-boss": "^12.25.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.0"
  }
}
